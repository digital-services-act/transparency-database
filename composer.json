{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "ext-zip": "*",
        "consoletvs/charts": "6.*",
        "cweagans/composer-patches": "^1.7",
        "ecphp/laravel-cas": "dev-main",
        "erusev/parsedown": "^1.7",
        "guzzlehttp/guzzle": "^7.2",
        "laravel/framework": "^13.0",
        "laravel/sanctum": "^4.3",
        "laravel/scout": "^11.1",
        "laravel/tinker": "^3.0",
        "laravel/vapor-core": "^2.43",
        "league/flysystem-aws-s3-v3": "^3.19",
        "maatwebsite/excel": "^3.1",
        "nyholm/psr7": "^1.8",
        "predis/predis": "^2.1",
        "spatie/laravel-honeypot": "^4.3",
        "spatie/laravel-permission": "^7.2",
        "stevebauman/purify": "^6.0",
        "symfony/cache": "^7.4",
        "symfony/intl": "^7.4",
        "symfony/psr-http-message-bridge": "^7.4",
        "tightenco/ziggy": "^1.6",
        "timwassenburg/laravel-pivot-table-generator": "^1.0",
        "yoeriboven/laravel-log-db": "^3.0",
        "zing/laravel-scout-opensearch": "^3.5"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^4.2",
        "brianium/paratest": "^7.8.5",
        "driftingly/rector-laravel": "^1.0",
        "fakerphp/faker": "^1.9.1",
        "laravel-shift/blueprint": "^2.13",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.55",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^8.9",
        "phpunit/phpunit": "^11.5.50",
        "rector/rector": "^1.0",
        "spatie/laravel-ignition": "^2.12"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        },
        "patches": {
            "apereo/phpcas": {
                "Ignore and bypass Session": "patches/apereo-phpcas.diff"
            },
            "subfission/cas": {
                "ServerBaseUrl": "patches/subfission-cas.diff"
            }
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "packages/ecphp/laravel-cas",
            "options": {
                "symlink": false
            }
        },
        {
            "type": "composer",
            "url": "https://repo.backpackforlaravel.com/"
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "cweagans/composer-patches": true,
            "cyclonedx/cyclonedx-php-composer": true,
            "php-http/discovery": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
